## Backend runtime
PORT=8080
PRODUCTION=false

## Auth
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

## Google OAuth
# Get from: console.cloud.google.com → Credentials → Web client ID
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

## Database (PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Public URL of your deployed backend (required for redirects + webhook URLs)
PUBLIC_BASE_URL=https://your-backend.onrender.com

## MyFatoorah (Visa/Master)
MYFATOORAH_API_KEY=REPLACE_ME
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
MYFATOORAH_WEBHOOK_SECRET=REPLACE_ME

## ZainCash
ZAINCASH_PRODUCTION=false
ZAINCASH_MSISDN=9647XXXXXXXXX
ZAINCASH_MERCHANT_ID=REPLACE_ME
ZAINCASH_SECRET=REPLACE_ME
ZAINCASH_SERVICE_TYPE=Charity App
ZAINCASH_LANG=ar

